        children: [
          const Text(
            'Welcome to Home',
            style: TextStyle(fontSize: 24, fontWeight: FontWeight.bold),
          ),
          const SizedBox(height: 8),
          Text(
            'Hello ${user?.name ?? "Guest"}, this is your home dashboard.',
            style: const TextStyle(color: Colors.grey),
          ),
        ],
      ),
    );
  }
}

