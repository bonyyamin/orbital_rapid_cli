import 'package:{{packageName}}/features/auth/data/models/user_model.dart';
import 'package:{{packageName}}/core/services/mock_auth_service.dart';
{{#isRiverpod}}
import 'package:flutter_riverpod/flutter_riverpod.dart';
{{/isRiverpod}}

/// Default implementation when no specific backend is selected.
/// This implementation uses the MockAuthService by default to allow
/// immediate testing of the UI.
class NoAuthRepository implements AuthRepositoryInterface {
  final _authStateController = StreamController<UserModel?>.broadcast();
  UserModel? _currentUser;

  NoAuthRepository() {
    // Emit initial null state
    _authStateController.add(null);
  }

  @override
  Stream<UserModel?> get authStateChanges {
    // Re-emit current state for new listeners
    Timer.run(() => _authStateController.add(_currentUser));
    return _authStateController.stream;
  }

  @override
  Future<UserModel> login(String email, String password) async {
    _currentUser = await MockAuthService.login(email, password);
    _authStateController.add(_currentUser);
    return _currentUser!;
  }

  @override
  Future<UserModel> register(String name, String email, String password) async {
    _currentUser = await MockAuthService.register(email, password, name);
    _authStateController.add(_currentUser);
    return _currentUser!;
  }

  @override
  Future<void> logout() async {
    await MockAuthService.logout();
    _currentUser = null;
    _authStateController.add(null);
  }

  @override
  Future<void> forgotPassword(String email) async {
    return await MockAuthService.forgotPassword(email);
  }

  @override
  Future<void> deleteAccount() async {
    _currentUser = null;
    _authStateController.add(null);
  }
}

{{#isRiverpod}}
final authRepositoryProvider = Provider<AuthRepositoryInterface>((ref) {
  return NoAuthRepository();
});
{{/isRiverpod}}
