import 'package:dio/dio.dart';
import 'package:{{packageName}}/core/network/api_client.dart';
import 'package:{{packageName}}/core/network/api_endpoints.dart';
import 'package:{{packageName}}/core/services/storage_service.dart';
import 'package:{{packageName}}/features/auth/data/auth_repository_interface.dart';
import 'package:{{packageName}}/features/auth/data/models/user_model.dart';

class RestAuthRepository implements AuthRepositoryInterface {
  final Dio _client;
  final StorageService _storage;

  // Auth state stream backed by a broadcast stream
  final _authStateController = Stream<UserModel?>.empty().asBroadcastStream();

  RestAuthRepository({required StorageService storage})
      : _storage = storage,
        _client = ApiClient.instance;

  @override
  Stream<UserModel?> get authStateChanges => _authStateController;

  @override
  Future<UserModel> login(String email, String password) async {
    final response = await _client.post(
      ApiEndpoints.login,
      data: {'email': email, 'password': password},
    );
    final data = response.data as Map<String, dynamic>;
    await _storage.setString('token', data['token'] as String);
    return UserModel.fromJson(data['user'] as Map<String, dynamic>);
  }

  @override
  Future<UserModel> register(String name, String email, String password) async {
    final response = await _client.post(
      ApiEndpoints.register,
      data: {'name': name, 'email': email, 'password': password},
    );
    final data = response.data as Map<String, dynamic>;
    await _storage.setString('token', data['token'] as String);
    return UserModel.fromJson(data['user'] as Map<String, dynamic>);
  }

  @override
  Future<void> logout() async {
    await _client.post(ApiEndpoints.logout);
    await _storage.remove('token');
  }

  @override
  Future<void> forgotPassword(String email) async {
    await _client.post(
      ApiEndpoints.forgotPassword,
      data: {'email': email},
    );
  }

  @override
  Future<void> deleteAccount() async {
    await _client.delete(ApiEndpoints.deleteAccount);
    await _storage.remove('token');
  }
}
