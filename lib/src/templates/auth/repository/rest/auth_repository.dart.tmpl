import 'dart:async';
import 'package:dio/dio.dart';
{{#isRiverpod}}
import 'package:flutter_riverpod/flutter_riverpod.dart';
{{/isRiverpod}}
import 'package:{{packageName}}/core/config/api_config.dart';
import 'package:{{packageName}}/core/network/api_client.dart';
import 'package:{{packageName}}/core/network/api_endpoints.dart';
import 'package:{{packageName}}/core/services/storage_service.dart';
import 'package:{{packageName}}/core/services/mock_auth_service.dart';
import 'package:{{packageName}}/features/auth/data/auth_repository_interface.dart';
import 'package:{{packageName}}/features/auth/data/models/user_model.dart';

class RestAuthRepository implements AuthRepositoryInterface {
  final Dio _client;
  final StorageService _storage;
  final bool _useMock;
  final _authStateController = StreamController<UserModel?>.broadcast();
  UserModel? _currentUser;

  RestAuthRepository({required StorageService storage, Dio? client})
      : _storage = storage,
        _client = client ?? ApiClient.instance,
        _useMock = ApiConfig.baseUrl == 'YOUR_API_BASE_URL';

  @override
  Stream<UserModel?> get authStateChanges {
    // Check for existing token and try to get user
    _initAuth();
    return _authStateController.stream;
  }

  Future<void> _initAuth() async {
    final token = await _storage.getString('token');
    if (token != null) {
      if (token.startsWith('mock-token-')) {
        _currentUser = await MockAuthService.getCurrentUser();
      } else {
        // In a real app, you would fetch user profile from API using token
        // For now, we'll use mock if API call fails
        try {
          // Mock fetch
          _currentUser = await MockAuthService.getCurrentUser();
        } catch (_) {
          _currentUser = null;
        }
      }
    } else {
      _currentUser = null;
    }
    _authStateController.add(_currentUser);
  }

  @override
  Future<UserModel> login(String email, String password) async {
    if (_useMock || (email == 'login@orbitalrapid.com' && password == '12345678')) {
      print('🔧 Using mock authentication for development');
      MockAuthService.printMockCredentials();
      _currentUser = await MockAuthService.login(email, password);
      await _storage.setString('token', 'mock-token-${_currentUser!.id}');
      _authStateController.add(_currentUser);
      return _currentUser!;
    }
    
    try {
      final response = await _client.post(
        ApiEndpoints.login,
        data: {'email': email, 'password': password},
      );
      final data = response.data as Map<String, dynamic>;
      await _storage.setString('token', data['token'] as String);
      _currentUser = UserModel.fromJson(data['user'] as Map<String, dynamic>);
      _authStateController.add(_currentUser);
      return _currentUser!;
    } catch (e) {
      if (email == 'login@orbitalrapid.com' && password == '12345678') {
        print('🔧 API login failed, falling back to mock authentication');
        _currentUser = await MockAuthService.login(email, password);
        await _storage.setString('token', 'mock-token-${_currentUser!.id}');
        _authStateController.add(_currentUser);
        return _currentUser!;
      }
      rethrow;
    }
  }

  @override
  Future<UserModel> register(String name, String email, String password) async {
    if (_useMock) {
      _currentUser = await MockAuthService.register(email, password, name);
      await _storage.setString('token', 'mock-token-${_currentUser!.id}');
      _authStateController.add(_currentUser);
      return _currentUser!;
    }
    
    try {
      final response = await _client.post(
        ApiEndpoints.register,
        data: {'name': name, 'email': email, 'password': password},
      );
      final data = response.data as Map<String, dynamic>;
      await _storage.setString('token', data['token'] as String);
      _currentUser = UserModel.fromJson(data['user'] as Map<String, dynamic>);
      _authStateController.add(_currentUser);
      return _currentUser!;
    } catch (e) {
      _currentUser = await MockAuthService.register(email, password, name);
      await _storage.setString('token', 'mock-token-${_currentUser!.id}');
      _authStateController.add(_currentUser);
      return _currentUser!;
    }
  }

  @override
  Future<void> logout() async {
    await _storage.remove('token');
    _currentUser = null;
    _authStateController.add(null);
    
    if (!_useMock) {
      try {
        await _client.post(ApiEndpoints.logout);
      } catch (_) {}
    }
  }

  @override
  Future<void> forgotPassword(String email) async {
    if (_useMock) {
      return await MockAuthService.forgotPassword(email);
    }
    
    try {
      await _client.post(
        ApiEndpoints.forgotPassword,
        data: {'email': email},
      );
    } catch (e) {
      return await MockAuthService.forgotPassword(email);
    }
  }

  @override
  Future<void> deleteAccount() async {
    await _storage.remove('token');
    _currentUser = null;
    _authStateController.add(null);
    
    if (!_useMock) {
      try {
        await _client.delete(ApiEndpoints.deleteAccount);
      } catch (_) {}
    }
  }

  @override
  Future<UserModel> loginWithGoogle() => _socialLogin('google');

  @override
  Future<UserModel> loginWithFacebook() => _socialLogin('facebook');

  @override
  Future<UserModel> loginWithApple() => _socialLogin('apple');

  @override
  Future<UserModel> loginWithGithub() => _socialLogin('github');

  Future<UserModel> _socialLogin(String provider) async {
    if (_useMock) {
      _currentUser = await MockAuthService.login('$provider@example.com', 'social');
      await _storage.setString('token', 'mock-token-${_currentUser!.id}');
      _authStateController.add(_currentUser);
      return _currentUser!;
    }

    try {
      // In a real REST API, you would first get the token from the social SDK
      // then send it to your backend. Here we assume the backend handles it.
      final response = await _client.post(
        '${ApiEndpoints.login}/$provider',
        data: {'access_token': 'PASTE_TOKEN_HERE'},
      );
      final data = response.data as Map<String, dynamic>;
      await _storage.setString('token', data['token'] as String);
      _currentUser = UserModel.fromJson(data['user'] as Map<String, dynamic>);
      _authStateController.add(_currentUser);
      return _currentUser!;
    } catch (e) {
      print('🔧 API social login failed, falling back to mock');
      _currentUser = await MockAuthService.login('$provider@example.com', 'social');
      await _storage.setString('token', 'mock-token-${_currentUser!.id}');
      _authStateController.add(_currentUser);
      return _currentUser!;
    }
  }
}

{{#isRiverpod}}
final authRepositoryProvider = Provider<AuthRepositoryInterface>((ref) {
  return RestAuthRepository(storage: ref.watch(storageServiceProvider));
});
{{/isRiverpod}}
