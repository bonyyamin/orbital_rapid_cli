import 'package:{{packageName}}/core/config/supabase_config.dart';
import 'package:{{packageName}}/core/services/mock_auth_service.dart';
import 'package:{{packageName}}/features/auth/data/auth_repository_interface.dart';
import 'package:{{packageName}}/features/auth/data/models/user_model.dart';

class SupabaseAuthRepository implements AuthRepositoryInterface {
  final SupabaseClient _client;
  final bool _useMock;

  SupabaseAuthRepository({SupabaseClient? client, bool? useMock})
      : _client = client ?? Supabase.instance.client,
        _useMock = useMock ?? SupabaseConfig.useMock;

  @override
  Stream<UserModel?> get authStateChanges {
    return _client.auth.onAuthStateChange.map((event) {
      final user = event.session?.user;
      if (user == null) return null;
      return UserModel(
        id: user.id,
        name: user.userMetadata?['name'] as String? ?? '',
        email: user.email ?? '',
        photoUrl: user.userMetadata?['avatar_url'] as String?,
      );
    });
  }

  @override
  Future<UserModel> login(String email, String password) async {
    // Use mock service if in mock mode
    if (_useMock) {
      print('🔧 Using mock authentication for development');
      SupabaseConfig.printConfigInfo();
      MockAuthService.printMockCredentials();
      return await MockAuthService.login(email, password);
    }
    
    try {
      final response = await _client.auth.signInWithPassword(
        email: email,
        password: password,
      );
      final user = response.user!;
      return UserModel(
        id: user.id,
        name: user.userMetadata?['name'] as String? ?? '',
        email: user.email ?? '',
        photoUrl: user.userMetadata?['avatar_url'] as String?,
      );
    } catch (e) {
      // Fallback to mock service for development
      if (email == 'login@orbitalrapid.com' && password == '12345678') {
        print('🔧 Supabase login failed, falling back to mock authentication');
        SupabaseConfig.printConfigInfo();
        MockAuthService.printMockCredentials();
        return await MockAuthService.login(email, password);
      }
      rethrow;
    }
  }

  @override
  Future<UserModel> register(String firstName, String lastName, String email, String password) async {
    final name = '$firstName $lastName';
    // Use mock service if in mock mode
    if (_useMock) {
      print('🔧 Using mock authentication for development');
      return await MockAuthService.register(email, password, name);
    }
    
    try {
      final response = await _client.auth.signUp(
        email: email,
        password: password,
        data: {
          'name': name,
          'first_name': firstName,
          'last_name': lastName,
        },
      );
      final user = response.user!;
      return UserModel(
        id: user.id,
        name: name,
        email: user.email ?? '',
        photoUrl: null,
      );
    } catch (e) {
      // Fallback to mock service for development
      print('🔧 Supabase registration failed, falling back to mock authentication');
      return await MockAuthService.register(email, password, name);
    }
  }

  @override
  Future<void> logout() async {
    if (_useMock) {
      print('🔧 Using mock authentication for development');
      return await MockAuthService.logout();
    }
    
    try {
      await _client.auth.signOut();
    } catch (e) {
      print('🔧 Supabase logout failed, using mock logout');
      await MockAuthService.logout();
    }
  }

  @override
  Future<void> forgotPassword(String email) async {
    if (_useMock) {
      print('🔧 Using mock authentication for development');
      return await MockAuthService.forgotPassword(email);
    }
    
    try {
      await _client.auth.resetPasswordForEmail(email);
    } catch (e) {
      print('🔧 Supabase password reset failed, falling back to mock authentication');
      return await MockAuthService.forgotPassword(email);
    }
  }

  @override
  Future<void> deleteAccount() async {
    if (_useMock) {
      print('🔧 Using mock authentication for development');
      return;
    }
    
    try {
      // Supabase requires a server-side function or Admin API for account deletion
      // Call your edge function or backend endpoint here
      await _client.functions.invoke('delete-account');
    } catch (e) {
      print('🔧 Supabase account deletion failed, but continuing');
    }
  }

  @override
  Future<void> verifyEmail(String code) async {
    if (_useMock) {
      return await MockAuthService.verifyEmail(code);
    }
    
    try {
{{#isEmailOtp}}
      final user = _client.auth.currentUser;
      if (user != null && user.email != null) {
         await _client.auth.verifyOTP(
           type: OtpType.signup,
           token: code,
           email: user.email!,
         );
      } else {
        throw Exception('User email not found for verification. Please login again.');
      }
{{/isEmailOtp}}
{{#isEmailLink}}
      // For link verification, the user clicks the link in their email.
      // We just need to check if the user session has been updated.
      final response = await _client.auth.refreshSession();
      if (response.user == null || response.user!.emailConfirmedAt == null) {
         throw Exception('Email is not verified yet. Please check your inbox.');
      }
{{/isEmailLink}}
    } catch (e) {
      throw Exception('Failed to verify email. Please check your code.');
    }
  }

  @override
  Future<void> resendVerification(String email) async {
    if (_useMock) {
      return await MockAuthService.resendVerification(email);
    }
    
    try {
      await _client.auth.resend(
        type: OtpType.signup,
        email: email,
      );
    } catch (e) {
      throw Exception('Failed to resend verification email.');
    }
  }

  @override
  Future<UserModel> loginWithGoogle() => _socialLogin(OAuthProvider.google);

  @override
  Future<UserModel> loginWithFacebook() => _socialLogin(OAuthProvider.facebook);

  @override
  Future<UserModel> loginWithApple() => _socialLogin(OAuthProvider.apple);

  @override
  Future<UserModel> loginWithGithub() => _socialLogin(OAuthProvider.github);

  Future<UserModel> _socialLogin(OAuthProvider provider) async {
    if (_useMock) {
      return await MockAuthService.login('${provider.name}@example.com', 'social');
    }

    final success = await _client.auth.signInWithOAuth(
      provider,
      redirectTo: '{{packageName}}://login-callback/',
    );

    if (!success) throw Exception('${provider.name} sign in failed');

    // OAuth flow usually redirects, so we return a dummy user that will be 
    // updated once the auth state listener triggers after redirect.
    return const UserModel(id: '', name: 'Redirecting...', email: '');
  }
}

{{#isRiverpod}}
final authRepositoryProvider = Provider<AuthRepositoryInterface>((ref) {
  return SupabaseAuthRepository();
});
{{/isRiverpod}}
