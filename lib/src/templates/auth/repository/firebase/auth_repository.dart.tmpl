class FirebaseAuthRepository implements AuthRepositoryInterface {
  final FirebaseAuth _auth;
  final bool _useMock;
  final _authStateController = StreamController<UserModel?>.broadcast();
  UserModel? _currentMockUser;

  FirebaseAuthRepository({FirebaseAuth? auth, bool? useMock}) 
      : _auth = auth ?? FirebaseAuth.instance,
        _useMock = useMock ?? false {
    // Listen to Firebase auth changes and pipe them to our controller
    _auth.authStateChanges().listen((user) {
      if (user != null) {
        final userModel = UserModel(
          id: user.uid,
          name: user.displayName ?? '',
          email: user.email ?? '',
          photoUrl: user.photoURL,
        );
        _authStateController.add(userModel);
      } else {
        // If Firebase user is null, we might still have a mock user
        _authStateController.add(_currentMockUser);
      }
    });
  }

  @override
  Stream<UserModel?> get authStateChanges {
    // Emit current state immediately to new listeners
    Timer.run(() {
      if (_auth.currentUser != null) {
        _authStateController.add(UserModel(
          id: _auth.currentUser!.uid,
          name: _auth.currentUser!.displayName ?? '',
          email: _auth.currentUser!.email ?? '',
          photoUrl: _auth.currentUser!.photoURL,
        ));
      } else {
        _authStateController.add(_currentMockUser);
      }
    });
    return _authStateController.stream;
  }

  @override
  Future<UserModel> login(String email, String password) async {
    // Use mock service if in mock mode or if using development credentials
    if (_useMock || (email == 'login@orbitalrapid.com' && password == '12345678')) {
      debugPrint('🔧 Using mock authentication for development');
      MockAuthService.printMockCredentials();
      _currentMockUser = await MockAuthService.login(email, password);
      _authStateController.add(_currentMockUser);
      return _currentMockUser!;
    }
    
    try {
      final credential = await _auth.signInWithEmailAndPassword(
        email: email,
        password: password,
      );
      final user = credential.user!;
      final userModel = UserModel(
        id: user.uid,
        name: user.displayName ?? '',
        email: user.email ?? '',
        photoUrl: user.photoURL,
      );
      return userModel;
    } catch (e) {
      // Fallback to mock service for development if specific credentials used
      if (email == 'login@orbitalrapid.com' && password == '12345678') {
        debugPrint('🔧 Firebase login failed, falling back to mock authentication');
        _currentMockUser = await MockAuthService.login(email, password);
        _authStateController.add(_currentMockUser);
        return _currentMockUser!;
      }
      rethrow;
    }
  }

  @override
  Future<UserModel> register(String firstName, String lastName, String email, String password) async {
    final name = '$firstName $lastName';
    if (_useMock) {
      _currentMockUser = await MockAuthService.register(email, password, name);
      _authStateController.add(_currentMockUser);
      return _currentMockUser!;
    }
    
    try {
      final credential = await _auth.createUserWithEmailAndPassword(
        email: email,
        password: password,
      );
      await credential.user!.updateDisplayName(name);
      final user = credential.user!;
      await user.sendEmailVerification();
      return UserModel(
        id: user.uid,
        name: name,
        email: user.email ?? '',
        photoUrl: user.photoURL,
      );
    } catch (e) {
      debugPrint('🔧 Firebase registration failed, falling back to mock authentication');
      _currentMockUser = await MockAuthService.register(email, password, name);
      _authStateController.add(_currentMockUser);
      return _currentMockUser!;
    }
  }

  @override
  Future<void> logout() async {
    await _auth.signOut();
    _currentMockUser = null;
    _authStateController.add(null);
  }

  @override
  Future<void> forgotPassword(String email) async {
    if (_useMock) {
      return await MockAuthService.forgotPassword(email);
    }
    
    try {
      await _auth.sendPasswordResetEmail(email: email);
    } catch (e) {
      debugPrint('🔧 Firebase password reset failed, falling back to mock authentication');
      return await MockAuthService.forgotPassword(email);
    }
  }

  @override
  Future<void> deleteAccount() async {
    if (_currentMockUser != null) {
      debugPrint('✅ Mock account deleted');
      _currentMockUser = null;
      _authStateController.add(null);
      return;
    }

    final user = _auth.currentUser;
    if (user == null) throw Exception('No authenticated user');
    await user.delete();
  }

  @override
  Future<void> verifyEmail(String code) async {
    if (_useMock) {
      return await MockAuthService.verifyEmail(code);
    }
    
    // For Firebase, 'code' might be an OOB code from a deep link, 
    // or we can just reload the user if we expect them to click a link elsewhere.
    if (code.isNotEmpty) {
      try {
        await _auth.applyActionCode(code);
      } catch (e) {
        throw Exception('Invalid or expired action code');
      }
    }
    
    final user = _auth.currentUser;
    if (user != null) {
      await user.reload();
      if (!user.emailVerified) {
        throw Exception('Email is not verified yet. Please check your inbox.');
      }
    }
  }

  @override
  Future<void> resendVerification(String email) async {
    if (_useMock) {
      return await MockAuthService.resendVerification(email);
    }
    
    final user = _auth.currentUser;
    if (user != null) {
      await user.sendEmailVerification();
    } else {
      throw Exception('No user is currently signed in to send verification.');
    }
  }

  @override
  Future<UserModel> loginWithGoogle() async {
    if (_useMock) return await MockAuthService.login('google@example.com', 'social');

    {{#hasGoogleAuth}}
    try {
      final googleSignIn = GoogleSignIn();
      final googleUser = await googleSignIn.signIn();
      if (googleUser == null) throw Exception('Google sign in cancelled');

      final googleAuth = await googleUser.authentication;
      final credential = GoogleAuthProvider.credential(
        idToken: googleAuth.idToken,
        accessToken: googleAuth.accessToken,
      );

      final userCredential = await _auth.signInWithCredential(credential);
      return _mapFirebaseUser(userCredential.user!);
    } catch (e) {
      throw Exception('Google sign in failed: $e');
    }
    {{/hasGoogleAuth}}
    {{^hasGoogleAuth}}
    throw UnimplementedError('Google sign in is not enabled for this project.');
    {{/hasGoogleAuth}}
  }

  @override
  Future<UserModel> loginWithFacebook() async {
    if (_useMock) return await MockAuthService.login('facebook@example.com', 'social');
    
    {{#hasFacebookAuth}}
    final result = await FacebookAuth.instance.login();
    if (result.status != LoginStatus.success) throw Exception('Facebook sign in failed: ${result.message}');
    
    final credential = FacebookAuthProvider.credential(result.accessToken!.tokenString);
    final userCredential = await _auth.signInWithCredential(credential);
    return _mapFirebaseUser(userCredential.user!);
    {{/hasFacebookAuth}}
    {{^hasFacebookAuth}}
    throw UnimplementedError('Facebook sign in is not enabled for this project.');
    {{/hasFacebookAuth}}
  }

  @override
  Future<UserModel> loginWithApple() async {
    if (_useMock) return await MockAuthService.login('apple@example.com', 'social');
    
    {{#hasAppleAuth}}
    final appleCredential = await SignInWithApple.getAppleIDCredential(
      scopes: [
        AppleIDAuthorizationScopes.email,
        AppleIDAuthorizationScopes.fullName,
      ],
    );
    
    final credential = OAuthProvider('apple.com').credential(
      idToken: appleCredential.identityToken,
      accessToken: appleCredential.authorizationCode,
    );
    
    final userCredential = await _auth.signInWithCredential(credential);
    return _mapFirebaseUser(userCredential.user!);
    {{/hasAppleAuth}}
    {{^hasAppleAuth}}
    throw UnimplementedError('Apple sign in is not enabled for this project.');
    {{/hasAppleAuth}}
  }

  @override
  Future<UserModel> loginWithGithub() async {
    if (_useMock) return await MockAuthService.login('github@example.com', 'social');
    
    {{#hasGithubAuth}}
    // GitHub typically uses OAuth flow
    final provider = GithubAuthProvider();
    final userCredential = await _auth.signInWithProvider(provider);
    return _mapFirebaseUser(userCredential.user!);
    {{/hasGithubAuth}}
    {{^hasGithubAuth}}
    throw UnimplementedError('GitHub sign in is not enabled for this project.');
    {{/hasGithubAuth}}
  }

  UserModel _mapFirebaseUser(User user) {
    return UserModel(
      id: user.uid,
      name: user.displayName ?? '',
      email: user.email ?? '',
      photoUrl: user.photoURL,
    );
  }
}

final authRepositoryProvider = Provider<AuthRepositoryInterface>((ref) {
  // Check if Firebase is using placeholder configuration
  final useMock = DefaultFirebaseOptions.currentPlatform.apiKey == 'YOUR_FIREBASE_API_KEY';
  return FirebaseAuthRepository(useMock: useMock);
});
