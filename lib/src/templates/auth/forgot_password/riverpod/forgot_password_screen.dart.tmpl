import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:{{projectName}}/core/utils/app_colors.dart';
import 'package:{{projectName}}/core/utils/app_text_styles.dart';
import 'package:{{projectName}}/core/utils/app_dimensions.dart';
import 'package:{{projectName}}/core/utils/app_strings.dart';
import 'package:{{projectName}}/shared/widgets/primary_button.dart';
import 'package:{{projectName}}/shared/widgets/text_input.dart';
import 'package:{{projectName}}/features/auth/presentation/forgot_password/riverpod/forgot_password_provider.dart';

class ForgotPasswordScreen extends ConsumerWidget {
  const ForgotPasswordScreen({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final state = ref.watch(forgotPasswordProvider);
    final notifier = ref.read(forgotPasswordProvider.notifier);

    if (state.isSuccess) {
      return Scaffold(
        backgroundColor: {{colorsClass}}.background,
        body: SafeArea(
          child: Padding(
            padding: const EdgeInsets.all({{dimensionsClass}}.lg),
            child: Column(mainAxisAlignment: MainAxisAlignment.center, children: [
              const Icon(Icons.mark_email_read_outlined, size: 72, color: {{colorsClass}}.success),
              const SizedBox(height: {{dimensionsClass}}.lg),
              Text('Check your inbox', style: {{textStylesClass}}.heading2, textAlign: TextAlign.center),
              const SizedBox(height: {{dimensionsClass}}.sm),
              Text('We sent a reset link to ${state.email}',
                  style: {{textStylesClass}}.bodyMedium.copyWith(color: {{colorsClass}}.textSecondary),
                  textAlign: TextAlign.center),
              const SizedBox(height: {{dimensionsClass}}.xxl),
              PrimaryButton(label: {{stringsClass}}.forgotBack, onPressed: () => Navigator.pop(context)),
            ]),
          ),
        ),
      );
    }

    return Scaffold(
      backgroundColor: {{colorsClass}}.background,
      appBar: AppBar(backgroundColor: Colors.transparent, elevation: 0,
          leading: const BackButton(color: {{colorsClass}}.textPrimary)),
      body: SafeArea(
        child: Padding(
          padding: const EdgeInsets.all({{dimensionsClass}}.lg),
          child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
            const SizedBox(height: {{dimensionsClass}}.lg),
            Text({{stringsClass}}.forgotTitle, style: {{textStylesClass}}.heading1),
            const SizedBox(height: {{dimensionsClass}}.xs),
            Text({{stringsClass}}.forgotSubtitle,
                style: {{textStylesClass}}.bodyMedium.copyWith(color: {{colorsClass}}.textSecondary)),
            const SizedBox(height: {{dimensionsClass}}.xxl),
            TextInput(label: {{stringsClass}}.loginEmail,
                keyboardType: TextInputType.emailAddress, onChanged: notifier.emailChanged),
            if (state.errorMessage != null) ...[
              const SizedBox(height: {{dimensionsClass}}.sm),
              Text(state.errorMessage!,
                  style: {{textStylesClass}}.caption.copyWith(color: {{colorsClass}}.error)),
            ],
            const SizedBox(height: {{dimensionsClass}}.xl),
            PrimaryButton(label: {{stringsClass}}.forgotButton,
                isLoading: state.isLoading, onPressed: notifier.submit),
          ]),
        ),
      ),
    );
  }
}
