import 'package:get/get.dart';
import 'package:{{packageName}}/features/auth/domain/usecases/forgot_password_usecase.dart';

class ForgotPasswordController extends GetxController {
  final ForgotPasswordUseCase _useCase;
  ForgotPasswordController(this._useCase);

  final RxString email = ''.obs;
  final RxBool isLoading = false.obs;
  final RxnString errorMessage = RxnString();
  final RxBool isSuccess = false.obs;

  Future<void> submit() async {
    if (email.value.isEmpty) return;
    isLoading.value = true;
    errorMessage.value = null;
    try {
      await _useCase(email.value);
      isSuccess.value = true;
    } catch (e) {
      errorMessage.value = e.toString();
    } finally {
      isLoading.value = false;
    }
  }

  void goBack() => Get.back();
}
