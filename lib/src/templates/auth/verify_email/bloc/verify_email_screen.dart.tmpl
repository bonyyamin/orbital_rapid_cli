import 'package:flutter/material.dart';
import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:{{projectName}}/core/utils/app_colors.dart';
import 'package:{{projectName}}/core/utils/app_text_styles.dart';
import 'package:{{projectName}}/core/utils/app_dimensions.dart';
import 'package:{{projectName}}/core/constants/app_routes.dart';
import 'package:{{projectName}}/shared/widgets/primary_button.dart';
import 'package:{{projectName}}/shared/widgets/text_input.dart';
import 'package:{{projectName}}/features/auth/presentation/verify_email/bloc/verify_email_bloc.dart';
import 'package:{{projectName}}/features/auth/presentation/verify_email/bloc/verify_email_event.dart';
import 'package:{{projectName}}/features/auth/presentation/verify_email/bloc/verify_email_state.dart';

class VerifyEmailScreen extends StatelessWidget {
  const VerifyEmailScreen({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: {{colorsClass}}.background,
      appBar: AppBar(backgroundColor: Colors.transparent, elevation: 0,
          leading: const BackButton(color: {{colorsClass}}.textPrimary)),
      body: BlocConsumer<VerifyEmailBloc, VerifyEmailState>(
        listener: (context, state) {
          if (state.isSuccess) Navigator.pushReplacementNamed(context, {{routesClass}}.home);
          if (state.errorMessage != null && state.errorMessage!.isNotEmpty) {
            ScaffoldMessenger.of(context).showSnackBar(
              SnackBar(content: Text(state.errorMessage!), backgroundColor: {{colorsClass}}.primary),
            );
          }
        },
        builder: (context, state) {
          final bloc = context.read<VerifyEmailBloc>();
          return SafeArea(
            child: SingleChildScrollView(
              padding: const EdgeInsets.all({{dimensionsClass}}.lg),
              child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
                Text('Verify Email', style: {{textStylesClass}}.heading1),
                const SizedBox(height: {{dimensionsClass}}.xs),
{{#isEmailOtp}}
                Text('Enter the verification code sent to your email',
                    style: {{textStylesClass}}.bodyMedium.copyWith(color: {{colorsClass}}.textSecondary)),
                const SizedBox(height: {{dimensionsClass}}.xxl),
                TextInput(
                  label: 'Verification Code', 
                  onChanged: (code) => bloc.add(VerifyEmailCodeChanged(code)),
                  keyboardType: TextInputType.number,
                ),
                const SizedBox(height: {{dimensionsClass}}.xl),
{{/isEmailOtp}}
{{#isEmailLink}}
                Text('Check your email for a verification link and click Verify once done',
                    style: {{textStylesClass}}.bodyMedium.copyWith(color: {{colorsClass}}.textSecondary)),
                const SizedBox(height: {{dimensionsClass}}.xxl),
{{/isEmailLink}}
                PrimaryButton(
                  label: 'Verify',
                  isLoading: state.isLoading, 
                  onPressed: () => bloc.add(VerifyEmailSubmitted()),
                ),
                const SizedBox(height: {{dimensionsClass}}.xl),
                Row(mainAxisAlignment: MainAxisAlignment.center, children: [
{{#isEmailOtp}}
                  Text("Didn't receive a code? ", style: {{textStylesClass}}.bodyMedium),
{{/isEmailOtp}}
{{#isEmailLink}}
                  Text("Didn't receive a link? ", style: {{textStylesClass}}.bodyMedium),
{{/isEmailLink}}
                  GestureDetector(
                    onTap: () => bloc.add(VerifyEmailResendRequested('current_user@example.com')),
                    child: Text('Resend',
                        style: {{textStylesClass}}.bodyMedium.copyWith(
                            color: {{colorsClass}}.primary, fontWeight: FontWeight.w600)),
                  ),
                ]),
              ]),
            ),
          );
        },
      ),
    );
  }
}
