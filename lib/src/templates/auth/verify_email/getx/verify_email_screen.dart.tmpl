import 'package:flutter/material.dart';
import 'package:get/get.dart';
import 'package:{{packageName}}/core/utils/app_colors.dart';
import 'package:{{packageName}}/core/utils/app_text_styles.dart';
import 'package:{{packageName}}/core/utils/app_dimensions.dart';
import 'package:{{packageName}}/shared/widgets/primary_button.dart';
import 'package:{{packageName}}/shared/widgets/text_input.dart';
import 'verify_email_controller.dart';

class VerifyEmailScreen extends GetView<VerifyEmailController> {
  const VerifyEmailScreen({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: {{colorsClass}}.background,
      appBar: AppBar(backgroundColor: Colors.transparent, elevation: 0,
          leading: const BackButton(color: {{colorsClass}}.textPrimary)),
      body: SafeArea(
        child: SingleChildScrollView(
          padding: const EdgeInsets.all({{dimensionsClass}}.lg),
          child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
            Text('Verify Email', style: {{textStylesClass}}.heading1),
            const SizedBox(height: {{dimensionsClass}}.xs),
{{#isEmailOtp}}
            Text('Enter the verification code sent to your email',
                style: {{textStylesClass}}.bodyMedium.copyWith(color: {{colorsClass}}.textSecondary)),
            const SizedBox(height: {{dimensionsClass}}.xxl),
            TextInput(
              label: 'Verification Code', 
              onChanged: controller.setCode,
              keyboardType: TextInputType.number,
            ),
            const SizedBox(height: {{dimensionsClass}}.xl),
{{/isEmailOtp}}
{{#isEmailLink}}
            Text('Check your email for a verification link and click Verify once done',
                style: {{textStylesClass}}.bodyMedium.copyWith(color: {{colorsClass}}.textSecondary)),
            const SizedBox(height: {{dimensionsClass}}.xxl),
{{/isEmailLink}}
            Obx(() => PrimaryButton(
              label: 'Verify',
              isLoading: controller.isLoading.value, 
              onPressed: controller.verify,
            )),
            const SizedBox(height: {{dimensionsClass}}.xl),
            Row(mainAxisAlignment: MainAxisAlignment.center, children: [
{{#isEmailOtp}}
              Text("Didn't receive a code? ", style: {{textStylesClass}}.bodyMedium),
{{/isEmailOtp}}
{{#isEmailLink}}
              Text("Didn't receive a link? ", style: {{textStylesClass}}.bodyMedium),
{{/isEmailLink}}
              GestureDetector(
                onTap: () => controller.resendVerification('current_user@example.com'),
                child: Text('Resend',
                    style: {{textStylesClass}}.bodyMedium.copyWith(
                        color: {{colorsClass}}.primary, fontWeight: FontWeight.w600)),
              ),
            ]),
          ]),
        ),
      ),
    );
  }
}
