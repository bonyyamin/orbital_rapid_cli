import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:{{packageName}}/features/auth/domain/usecases/register_usecase.dart';
import 'register_event.dart';
import 'register_state.dart';

class RegisterBloc extends Bloc<RegisterEvent, RegisterState> {
  final RegisterUseCase _registerUseCase;

  RegisterBloc(this._registerUseCase) : super(const RegisterState()) {
    on<RegisterFirstNameChanged>((e, emit) => emit(state.copyWith(firstName: e.firstName, status: RegisterStatus.initial)));
    on<RegisterLastNameChanged>((e, emit) => emit(state.copyWith(lastName: e.lastName, status: RegisterStatus.initial)));
    on<RegisterEmailChanged>((e, emit) => emit(state.copyWith(email: e.email, status: RegisterStatus.initial)));
    on<RegisterPasswordChanged>((e, emit) => emit(state.copyWith(password: e.password, status: RegisterStatus.initial)));
    on<RegisterConfirmPasswordChanged>((e, emit) => emit(state.copyWith(confirmPassword: e.confirmPassword, status: RegisterStatus.initial)));
    on<RegisterSubmitted>(_onSubmitted);
  }

  Future<void> _onSubmitted(RegisterSubmitted event, Emitter<RegisterState> emit) async {
    if (!state.canSubmit) {
      emit(state.copyWith(status: RegisterStatus.failure, errorMessage: 'Please fill in all fields correctly'));
      return;
    }
    emit(state.copyWith(status: RegisterStatus.loading));
    try {
      await _registerUseCase(state.firstName, state.lastName, state.email, state.password);
      emit(state.copyWith(status: RegisterStatus.success));
    } catch (e) {
      emit(state.copyWith(status: RegisterStatus.failure, errorMessage: e.toString()));
    }
  }
}
