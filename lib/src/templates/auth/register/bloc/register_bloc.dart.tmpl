import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:{{packageName}}/features/auth/domain/usecases/register_usecase.dart';
import 'register_event.dart';
import 'register_state.dart';

class RegisterBloc extends Bloc<RegisterEvent, RegisterState> {
  final RegisterUseCase _registerUseCase;
  String _name = '';
  String _email = '';
  String _password = '';
  String _confirmPassword = '';

  RegisterBloc(this._registerUseCase) : super(const RegisterInitial()) {
    on<RegisterNameChanged>((e, emit) => _name = e.name);
    on<RegisterEmailChanged>((e, emit) => _email = e.email);
    on<RegisterPasswordChanged>((e, emit) => _password = e.password);
    on<RegisterConfirmPasswordChanged>((e, emit) => _confirmPassword = e.confirmPassword);
    on<RegisterSubmitted>(_onSubmitted);
  }

  Future<void> _onSubmitted(RegisterSubmitted event, Emitter<RegisterState> emit) async {
    if (_password != _confirmPassword) {
      emit(const RegisterFailure('Passwords do not match'));
      return;
    }
    emit(const RegisterLoading());
    try {
      await _registerUseCase(_name, _email, _password);
      emit(const RegisterSuccess());
    } catch (e) {
      emit(RegisterFailure(e.toString()));
    }
  }
}
