import 'package:flutter/material.dart';
import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:{{projectName}}/core/utils/app_colors.dart';
import 'package:{{projectName}}/core/utils/app_text_styles.dart';
import 'package:{{projectName}}/core/utils/app_dimensions.dart';
import 'package:{{projectName}}/core/utils/app_strings.dart';
import 'package:{{projectName}}/core/constants/app_routes.dart';
import 'package:{{projectName}}/shared/widgets/primary_button.dart';
import 'package:{{projectName}}/shared/widgets/text_input.dart';
import 'package:{{projectName}}/features/auth/presentation/register/bloc/register_bloc.dart';
import 'package:{{projectName}}/features/auth/presentation/register/bloc/register_event.dart';
import 'package:{{projectName}}/features/auth/presentation/register/bloc/register_state.dart';

class RegisterScreen extends StatelessWidget {
  const RegisterScreen({super.key});

  @override
  Widget build(BuildContext context) {
    return BlocListener<RegisterBloc, RegisterState>(
      listener: (context, state) {
        if (state.status == RegisterStatus.success) {
          {{#shouldVerifyEmail}}
          Navigator.pushReplacementNamed(context, {{routesClass}}.verifyEmail);
          {{/shouldVerifyEmail}}
          {{^shouldVerifyEmail}}
          Navigator.pushReplacementNamed(context, {{routesClass}}.home);
          {{/shouldVerifyEmail}}
        }
        if (state.status == RegisterStatus.failure && state.errorMessage != null) {
          ScaffoldMessenger.of(context).showSnackBar(
            SnackBar(content: Text(state.errorMessage!), backgroundColor: {{colorsClass}}.error),
          );
        }
      },
      child: Scaffold(
        backgroundColor: {{colorsClass}}.background,
        appBar: AppBar(backgroundColor: Colors.transparent, elevation: 0,
            leading: const BackButton(color: {{colorsClass}}.textPrimary)),
        body: SafeArea(
          child: BlocBuilder<RegisterBloc, RegisterState>(
            builder: (context, state) => SingleChildScrollView(
              padding: const EdgeInsets.all({{dimensionsClass}}.lg),
              child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
                Text({{stringsClass}}.registerTitle, style: {{textStylesClass}}.heading1),
                const SizedBox(height: {{dimensionsClass}}.xs),
                Text({{stringsClass}}.registerSubtitle,
                    style: {{textStylesClass}}.bodyMedium.copyWith(color: {{colorsClass}}.textSecondary)),
                const SizedBox(height: {{dimensionsClass}}.xxl),
                Row(children: [
                  Expanded(child: TextInput(label: {{stringsClass}}.registerFirstName,
                      onChanged: (v) => context.read<RegisterBloc>().add(RegisterFirstNameChanged(v)))),
                  const SizedBox(width: {{dimensionsClass}}.md),
                  Expanded(child: TextInput(label: {{stringsClass}}.registerLastName,
                      onChanged: (v) => context.read<RegisterBloc>().add(RegisterLastNameChanged(v)))),
                ]),
                const SizedBox(height: {{dimensionsClass}}.md),
                TextInput(
                  label: {{stringsClass}}.registerEmail,
                  keyboardType: TextInputType.emailAddress,
                  onChanged: (v) => context.read<RegisterBloc>().add(RegisterEmailChanged(v)),
                  errorText: state.email.isNotEmpty && !state.email.contains('@') ? {{stringsClass}}.valEmailInvalid : null,
                ),
                const SizedBox(height: {{dimensionsClass}}.md),
                TextInput(
                  label: {{stringsClass}}.registerPassword,
                  isPassword: true,
                  onChanged: (v) => context.read<RegisterBloc>().add(RegisterPasswordChanged(v)),
                  errorText: state.password.isNotEmpty && state.password.length < 6 ? {{stringsClass}}.valPasswordTooShort : null,
                ),
                const SizedBox(height: {{dimensionsClass}}.md),
                TextInput(
                  label: {{stringsClass}}.registerConfirm,
                  isPassword: true,
                  onChanged: (v) => context.read<RegisterBloc>().add(RegisterConfirmPasswordChanged(v)),
                  errorText: state.confirmPassword.isNotEmpty && !state.passwordsMatch ? {{stringsClass}}.valPasswordsMatch : null,
                ),
                const SizedBox(height: {{dimensionsClass}}.xl),
                PrimaryButton(label: {{stringsClass}}.registerButton,
                    isLoading: state.status == RegisterStatus.loading,
                    onPressed: state.canSubmit ? () => context.read<RegisterBloc>().add(const RegisterSubmitted()) : null),
                const SizedBox(height: {{dimensionsClass}}.xl),
                Row(mainAxisAlignment: MainAxisAlignment.center, children: [
                  Text({{stringsClass}}.registerHaveAccount, style: {{textStylesClass}}.bodyMedium),
                  GestureDetector(
                    onTap: () => Navigator.pop(context),
                    child: Text({{stringsClass}}.registerSignIn,
                        style: {{textStylesClass}}.bodyMedium.copyWith(
                            color: {{colorsClass}}.primary, fontWeight: FontWeight.w600)),
                  ),
                ]),
              ]),
            ),
          ),
        ),
      ),
    );
  }
}
