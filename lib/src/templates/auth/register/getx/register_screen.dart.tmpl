import 'package:flutter/material.dart';
import 'package:get/get.dart';
import 'package:{{projectName}}/core/utils/app_colors.dart';
import 'package:{{projectName}}/core/utils/app_text_styles.dart';
import 'package:{{projectName}}/core/utils/app_dimensions.dart';
import 'package:{{projectName}}/core/utils/app_strings.dart';
import 'package:{{projectName}}/shared/widgets/primary_button.dart';
import 'package:{{projectName}}/shared/widgets/text_input.dart';
import 'package:{{projectName}}/features/auth/presentation/register/getx/register_controller.dart';

class RegisterScreen extends GetView<RegisterController> {
  const RegisterScreen({super.key});

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: {{colorsClass}}.background,
      appBar: AppBar(backgroundColor: Colors.transparent, elevation: 0,
          leading: const BackButton(color: {{colorsClass}}.textPrimary)),
      body: SafeArea(
        child: SingleChildScrollView(
          padding: const EdgeInsets.all({{dimensionsClass}}.lg),
          child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
            Text({{stringsClass}}.registerTitle, style: {{textStylesClass}}.heading1),
            const SizedBox(height: {{dimensionsClass}}.xs),
            Text({{stringsClass}}.registerSubtitle,
                style: {{textStylesClass}}.bodyMedium.copyWith(color: {{colorsClass}}.textSecondary)),
            const SizedBox(height: {{dimensionsClass}}.xxl),
            Row(children: [
              Expanded(child: TextInput(label: {{stringsClass}}.registerFirstName,
                  onChanged: (v) => controller.firstName.value = v)),
              const SizedBox(width: {{dimensionsClass}}.md),
              Expanded(child: TextInput(label: {{stringsClass}}.registerLastName,
                  onChanged: (v) => controller.lastName.value = v)),
            ]),
            const SizedBox(height: {{dimensionsClass}}.md),
            Obx(() => TextInput(
              label: {{stringsClass}}.registerEmail,
              keyboardType: TextInputType.emailAddress,
              onChanged: (v) => controller.email.value = v,
              errorText: controller.email.isNotEmpty && !controller.email.contains('@') ? {{stringsClass}}.valEmailInvalid : null,
            )),
            const SizedBox(height: {{dimensionsClass}}.md),
            Obx(() => TextInput(
              label: {{stringsClass}}.registerPassword,
              isPassword: true,
              onChanged: (v) => controller.password.value = v,
              errorText: controller.password.isNotEmpty && controller.password.value.length < 6 ? {{stringsClass}}.valPasswordTooShort : null,
            )),
            const SizedBox(height: {{dimensionsClass}}.md),
            Obx(() => TextInput(
              label: {{stringsClass}}.registerConfirm,
              isPassword: true,
              onChanged: (v) => controller.confirmPassword.value = v,
              errorText: controller.confirmPassword.isNotEmpty && !controller.passwordsMatch ? {{stringsClass}}.valPasswordsMatch : null,
            )),
            const SizedBox(height: {{dimensionsClass}}.xl),
            Obx(() => PrimaryButton(label: {{stringsClass}}.registerButton,
                isLoading: controller.isLoading.value, onPressed: controller.canSubmit ? controller.submit : null)),
            Obx(() {
              final err = controller.errorMessage.value;
              if (err == null) return const SizedBox.shrink();
              return Padding(padding: const EdgeInsets.only(top: {{dimensionsClass}}.sm),
                  child: Text(err, style: {{textStylesClass}}.caption.copyWith(color: {{colorsClass}}.error)));
            }),
            const SizedBox(height: {{dimensionsClass}}.xl),
            Row(mainAxisAlignment: MainAxisAlignment.center, children: [
              Text({{stringsClass}}.registerHaveAccount, style: {{textStylesClass}}.bodyMedium),
              GestureDetector(onTap: controller.goToLogin,
                  child: Text({{stringsClass}}.registerSignIn,
                      style: {{textStylesClass}}.bodyMedium.copyWith(
                          color: {{colorsClass}}.primary, fontWeight: FontWeight.w600))),
            ]),
          ]),
        ),
      ),
    );
  }
}
