import 'package:flutter/material.dart';
import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:{{projectName}}/core/utils/app_colors.dart';
import 'package:{{projectName}}/core/utils/app_text_styles.dart';
import 'package:{{projectName}}/core/utils/app_dimensions.dart';
import 'package:{{projectName}}/core/utils/app_strings.dart';
import 'package:{{projectName}}/core/constants/app_routes.dart';
import 'package:{{projectName}}/shared/widgets/primary_button.dart';
import 'package:{{projectName}}/features/auth/presentation/login/riverpod/login_provider.dart';
import 'package:{{projectName}}/features/auth/presentation/login/widgets/login_form.dart';
import 'package:{{projectName}}/shared/widgets/social_login_button.dart';

class LoginScreen extends ConsumerWidget {
  const LoginScreen({super.key});

  @override
  Widget build(BuildContext context, WidgetRef ref) {
    final state = ref.watch(loginProvider);
    final notifier = ref.read(loginProvider.notifier);

    ref.listen(loginProvider, (_, next) {
      if (next.isSuccess) {
        Navigator.pushReplacementNamed(context, {{routesClass}}.home);
      }
      if (next.errorMessage != null) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: Text(next.errorMessage!),
            backgroundColor: {{colorsClass}}.error,
          ),
        );
      }
    });

    return Scaffold(
      backgroundColor: {{colorsClass}}.background,
      body: SafeArea(
        child: SingleChildScrollView(
          padding: const EdgeInsets.all({{dimensionsClass}}.lg),
          child: Column(
            crossAxisAlignment: CrossAxisAlignment.start,
            children: [
              const SizedBox(height: {{dimensionsClass}}.xxl),
              Text({{stringsClass}}.loginTitle, style: {{textStylesClass}}.heading1),
              const SizedBox(height: {{dimensionsClass}}.xs),
              Text({{stringsClass}}.loginSubtitle,
                  style: {{textStylesClass}}.bodyMedium.copyWith(color: {{colorsClass}}.textSecondary)),
              const SizedBox(height: {{dimensionsClass}}.xxl),
              LoginForm(
                onEmailChanged: notifier.emailChanged,
                onPasswordChanged: notifier.passwordChanged,
              ),
              Align(
                alignment: Alignment.centerRight,
                child: TextButton(
                  onPressed: () => Navigator.pushNamed(context, {{routesClass}}.forgotPassword),
                  child: Text({{stringsClass}}.loginForgot,
                      style: {{textStylesClass}}.label.copyWith(color: {{colorsClass}}.primary)),
                ),
              ),
              const SizedBox(height: {{dimensionsClass}}.md),
              PrimaryButton(
                label: {{stringsClass}}.loginButton,
                isLoading: state.isLoading,
                onPressed: notifier.submit,
              ),
              const SizedBox(height: {{dimensionsClass}}.xl),
              Row(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  Text({{stringsClass}}.loginNoAccount, style: {{textStylesClass}}.bodyMedium),
                  GestureDetector(
                    onTap: () => Navigator.pushNamed(context, {{routesClass}}.register),
                    child: Text({{stringsClass}}.loginSignUp,
                        style: {{textStylesClass}}.bodyMedium.copyWith(
                          color: {{colorsClass}}.primary,
                          fontWeight: FontWeight.w600,
                        )),
                  ),
                ],
              ),
              {{#hasSocialAuth}}
              const SizedBox(height: {{dimensionsClass}}.xl),
              Row(
                children: [
                  const Expanded(child: Divider()),
                  Padding(
                    padding: const EdgeInsets.symmetric(horizontal: {{dimensionsClass}}.md),
                    child: Text('OR', style: {{textStylesClass}}.label.copyWith(color: {{colorsClass}}.textSecondary)),
                  ),
                  const Expanded(child: Divider()),
                ],
              ),
              const SizedBox(height: {{dimensionsClass}}.xl),
              {{#hasGoogleAuth}}
              SocialLoginButton(
                type: SocialType.google,
                onPressed: notifier.loginWithGoogle,
              ),
              const SizedBox(height: {{dimensionsClass}}.md),
              {{/hasGoogleAuth}}
              {{#hasFacebookAuth}}
              SocialLoginButton(
                type: SocialType.facebook,
                onPressed: notifier.loginWithFacebook,
              ),
              const SizedBox(height: {{dimensionsClass}}.md),
              {{/hasFacebookAuth}}
              {{#hasAppleAuth}}
              SocialLoginButton(
                type: SocialType.apple,
                onPressed: notifier.loginWithApple,
              ),
              const SizedBox(height: {{dimensionsClass}}.md),
              {{/hasAppleAuth}}
              {{#hasGithubAuth}}
              SocialLoginButton(
                type: SocialType.github,
                onPressed: notifier.loginWithGithub,
              ),
              const SizedBox(height: {{dimensionsClass}}.md),
              {{/hasGithubAuth}}
              {{/hasSocialAuth}}
            ],
          ),
        ),
      ),
    );
  }
}
