import 'package:flutter/material.dart';
import 'package:{{packageName}}/core/utils/app_text_styles.dart';
import 'package:{{packageName}}/core/utils/app_dimensions.dart';
import 'package:{{packageName}}/core/utils/app_colors.dart';

class OnboardingPage extends StatelessWidget {
  final String title;
  final String subtitle;
  final String image;

  const OnboardingPage({
    super.key,
    required this.title,
    required this.subtitle,
    required this.image,
  });

  @override
  Widget build(BuildContext context) {
    return Padding(
      padding: const EdgeInsets.all({{dimensionsClass}}.lg),
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          Expanded(
            flex: 3,
            child: Image.asset(
              image,
              fit: BoxFit.contain,
            ),
          ),
          const SizedBox(height: {{dimensionsClass}}.xxl),
          Expanded(
            flex: 2,
            child: Column(
              children: [
                Text(
                  title,
                  style: {{textStylesClass}}.heading1,
                  textAlign: TextAlign.center,
                ),
                const SizedBox(height: {{dimensionsClass}}.md),
                Text(
                  subtitle,
                  style: {{textStylesClass}}.bodyLarge.copyWith(
                    color: {{colorsClass}}.textSecondary,
                  ),
                  textAlign: TextAlign.center,
                ),
              ],
            ),
          ),
        ],
      ),
    );
  }
}
