import 'package:flutter/material.dart';
import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:{{projectName}}/core/utils/app_colors.dart';
import 'package:{{projectName}}/core/utils/app_text_styles.dart';
import 'package:{{projectName}}/core/utils/app_dimensions.dart';
import 'package:{{projectName}}/core/utils/app_strings.dart';
import 'package:{{projectName}}/core/constants/app_routes.dart';
import 'package:{{projectName}}/shared/widgets/primary_button.dart';
import 'package:{{projectName}}/features/onboarding/presentation/bloc/onboarding_bloc.dart';
import 'package:{{projectName}}/features/onboarding/presentation/bloc/onboarding_event.dart';
import 'package:{{projectName}}/features/onboarding/presentation/bloc/onboarding_state.dart';
import 'package:{{projectName}}/features/onboarding/presentation/widgets/onboarding_page.dart';
import 'package:{{projectName}}/features/onboarding/presentation/widgets/page_indicator.dart';

class OnboardingScreen extends StatefulWidget {
  const OnboardingScreen({super.key});

  @override
  State<OnboardingScreen> createState() => _OnboardingScreenState();
}

class _OnboardingScreenState extends State<OnboardingScreen> {
  final PageController _pageController = PageController();

  @override
  void dispose() {
    _pageController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    // Placeholder data
    final List<Map<String, dynamic>> pages = [
      {
        'title': 'Welcome to {{projectNamePascal}}',
        'subtitle': 'The fastest way to build your next Flutter app.',
        'icon': Icons.rocket_launch_rounded,
      },
      {
        'title': 'Clean Architecture',
        'subtitle': 'Maintainable, scalable, and testable code out of the box.',
        'icon': Icons.architecture_rounded,
      },
      {
        'title': 'Design System',
        'subtitle': 'Token-based system for easy branding and customization.',
        'icon': Icons.palette_rounded,
      },
    ];

    return Scaffold(
      backgroundColor: {{colorsClass}}.background,
      body: SafeArea(
        child: BlocBuilder<OnboardingBloc, OnboardingState>(
          builder: (context, state) {
            return Column(
              children: [
                Align(
                  alignment: Alignment.topRight,
                  child: TextButton(
                    onPressed: () => Navigator.pushReplacementNamed(context, {{routesClass}}.login),
                    child: Text(
                      {{stringsClass}}.onboardingSkip,
                      style: {{textStylesClass}}.button.copyWith(color: {{colorsClass}}.primary),
                    ),
                  ),
                ),
                Expanded(
                  child: PageView.builder(
                    controller: _pageController,
                    itemCount: pages.length,
                    onPageChanged: (index) {
                      context.read<OnboardingBloc>().add(
                        OnboardingPageUpdated(page: index, totalPages: pages.length),
                      );
                    },
                    itemBuilder: (context, index) {
                      final page = pages[index];
                      return OnboardingPage(
                        title: page['title']!,
                        subtitle: page['subtitle']!,
                        icon: page['icon']!,
                      );
                    },
                  ),
                ),
                Padding(
                  padding: const EdgeInsets.all({{dimensionsClass}}.lg),
                  child: Column(
                    children: [
                      PageIndicator(
                        count: pages.length,
                        current: state.currentPage,
                      ),
                      const SizedBox(height: {{dimensionsClass}}.xl),
                      PrimaryButton(
                        label: state.isLastPage  
                            ? {{stringsClass}}.onboardingDone 
                            : {{stringsClass}}.onboardingNext,
                        onPressed: () {
                          if (state.isLastPage) {
                            Navigator.pushReplacementNamed(context, {{routesClass}}.login);
                          } else {
                            _pageController.nextPage(
                              duration: const Duration(milliseconds: 300),
                              curve: Curves.easeInOut,
                            );
                          }
                        },
                      ),
                    ],
                  ),
                ),
              ],
            );
          },
        ),
      ),
    );
  }
}
