import 'package:flutter/material.dart';
import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:{{projectName}}/core/utils/app_colors.dart';
import 'package:{{projectName}}/core/utils/app_dimensions.dart';
import 'package:{{projectName}}/core/constants/app_routes.dart';
import 'package:{{projectName}}/features/splash/presentation/bloc/splash_bloc.dart';
import 'package:{{projectName}}/features/splash/presentation/bloc/splash_event.dart';
import 'package:{{projectName}}/features/splash/presentation/bloc/splash_state.dart';

class SplashScreen extends StatefulWidget {
  const SplashScreen({super.key});

  @override
  State<SplashScreen> createState() => _SplashScreenState();
}

class _SplashScreenState extends State<SplashScreen> {
  @override
  void initState() {
    super.initState();
    context.read<SplashBloc>().add(SplashAppStarted());
  }

  @override
  Widget build(BuildContext context) {
    return BlocListener<SplashBloc, SplashState>(
      listener: (context, state) {
        if (state is SplashNavigateToOnboarding) {
          Navigator.pushReplacementNamed(context, AppRoutes.onboarding);
        } else if (state is SplashNavigateToLogin) {
          Navigator.pushReplacementNamed(context, AppRoutes.login);
        }
      },
      child: Scaffold(
        body: Container(
          color: {{colorsClass}}.primary,
          child: Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                Icon(
                  Icons.rocket_launch_rounded,
                  size: {{dimensionsClass}}.splashLogoSize,
                  color: {{colorsClass}}.textOnPrimary,
                ),
                const SizedBox(height: {{dimensionsClass}}.md),
                const CircularProgressIndicator(
                  valueColor: AlwaysStoppedAnimation<Color>({{colorsClass}}.textOnPrimary),
                ),
              ],
            ),
          ),
        ),
      ),
    );
  }
}
