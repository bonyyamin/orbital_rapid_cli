import 'package:flutter/material.dart';
import 'package:flutter_bloc/flutter_bloc.dart';
import 'package:{{projectName}}/core/utils/app_colors.dart';
import 'package:{{projectName}}/core/utils/app_dimensions.dart';
import 'package:{{projectName}}/core/utils/app_strings.dart';
import 'package:{{projectName}}/core/utils/app_text_styles.dart';
import 'package:{{projectName}}/shared/widgets/primary_button.dart';
import 'package:{{projectName}}/shared/widgets/text_input.dart';
import 'package:{{projectName}}/features/account/presentation/delete/bloc/delete_account_bloc.dart';
import 'package:{{projectName}}/features/account/presentation/delete/bloc/delete_account_event.dart';
import 'package:{{projectName}}/features/account/presentation/delete/bloc/delete_account_state.dart';
import 'package:{{projectName}}/core/constants/app_routes.dart';

class DeleteAccountScreen extends StatefulWidget {
  const DeleteAccountScreen({super.key});

  @override
  State<DeleteAccountScreen> createState() => _DeleteAccountScreenState();
}

class _DeleteAccountScreenState extends State<DeleteAccountScreen> {
  final TextEditingController _confirmationController = TextEditingController();

  @override
  void dispose() {
    _confirmationController.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    return BlocListener<DeleteAccountBloc, DeleteAccountState>(
      listener: (context, state) {
        if (state is DeleteAccountSuccess) {
          Future.delayed(const Duration(seconds: 3), () {
            if (context.mounted) {
              Navigator.pushNamedAndRemoveUntil(
                context,
                AppRoutes.login,
                (route) => false,
              );
            }
          });
        }
      },
      child: BlocBuilder<DeleteAccountBloc, DeleteAccountState>(
        builder: (context, state) {
          if (state is DeleteAccountSuccess) {
            return Scaffold(
              backgroundColor: {{colorsClass}}.background,
              body: SafeArea(
                child: Padding(
                  padding: const EdgeInsets.all({{dimensionsClass}}.lg),
                  child: Column(
                    mainAxisAlignment: MainAxisAlignment.center,
                    children: [
                      const Icon(
                        Icons.check_circle_outline,
                        size: 72,
                        color: {{colorsClass}}.success,
                      ),
                      const SizedBox(height: {{dimensionsClass}}.lg),
                      Text(
                        'Account deleted',
                        style: {{textStylesClass}}.heading2,
                        textAlign: TextAlign.center,
                      ),
                      const SizedBox(height: {{dimensionsClass}}.sm),
                      Text(
                        'Your account has been permanently removed.',
                        style: {{textStylesClass}}.bodyMedium.copyWith(
                          color: {{colorsClass}}.textSecondary,
                        ),
                        textAlign: TextAlign.center,
                      ),
                      const SizedBox(height: {{dimensionsClass}}.xl),
                      PrimaryButton(
                        label: 'Back to Login',
                        onPressed: () {
                          Navigator.pushNamedAndRemoveUntil(
                            context,
                            AppRoutes.login,
                            (route) => false,
                          );
                        },
                      ),
                    ],
                  ),
                ),
              ),
            );
          }

          return Scaffold(
            backgroundColor: {{colorsClass}}.background,
            appBar: AppBar(
              backgroundColor: Colors.transparent,
              elevation: 0,
              leading: const BackButton(color: {{colorsClass}}.textPrimary),
            ),
            body: SafeArea(
              child: Padding(
                padding: const EdgeInsets.all({{dimensionsClass}}.lg),
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    const SizedBox(height: {{dimensionsClass}}.md),
                    Text({{stringsClass}}.accountDelete, style: {{textStylesClass}}.heading1),
                    const SizedBox(height: {{dimensionsClass}}.sm),
                    Text(
                      'This action is permanent. Type DELETE to confirm.',
                      style: {{textStylesClass}}.bodyMedium.copyWith(
                        color: {{colorsClass}}.textSecondary,
                      ),
                    ),
                    const SizedBox(height: {{dimensionsClass}}.xl),
                    TextInput(
                      label: 'Type DELETE',
                      controller: _confirmationController,
                    ),
                    if (state is DeleteAccountFailure) ...[
                      const SizedBox(height: {{dimensionsClass}}.sm),
                      Text(
                        state.message,
                        style: {{textStylesClass}}.caption.copyWith(
                          color: {{colorsClass}}.error,
                        ),
                      ),
                    ],
                    const SizedBox(height: {{dimensionsClass}}.xl),
                    PrimaryButton(
                      label: {{stringsClass}}.accountDelete,
                      isLoading: state is DeleteAccountLoading,
                      onPressed: () => context.read<DeleteAccountBloc>().add(
                            DeleteAccountConfirmationChanged(_confirmationController.text),
                          ),
                    ),
                  ],
                ),
              ),
            ),
          );
        },
      ),
    );
  }
}
