import 'package:flutter_riverpod/flutter_riverpod.dart';
import 'package:flutter_riverpod/legacy.dart';
import 'delete_account_notifier.dart';
import 'delete_account_state.dart';

final deleteAccountActionProvider = Provider<DeleteAccountAction>((ref) {
  return () async {
    // Mock deletion delay to simulate network request
    await Future.delayed(const Duration(seconds: 2));
    // In a real app, this would call a repository to delete the user account
  };
});

final deleteAccountProvider =
    StateNotifierProvider.autoDispose<DeleteAccountNotifier, DeleteAccountState>((ref) {
  return DeleteAccountNotifier(ref.watch(deleteAccountActionProvider));
});
