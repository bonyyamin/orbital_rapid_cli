import 'package:flutter/material.dart';
import 'package:get/get.dart';
import 'package:{{packageName}}/core/utils/app_colors.dart';
import 'package:{{packageName}}/core/utils/app_dimensions.dart';
import 'package:{{packageName}}/core/utils/app_strings.dart';
import 'package:{{packageName}}/core/utils/app_text_styles.dart';
import 'package:{{packageName}}/shared/widgets/primary_button.dart';
import 'package:{{packageName}}/shared/widgets/text_input.dart';
import 'package:{{packageName}}/features/account/presentation/delete/getx/delete_account_controller.dart';

class DeleteAccountScreen extends GetView<DeleteAccountController> {
  const DeleteAccountScreen({super.key});

  @override
  Widget build(BuildContext context) {
    return Obx(() {
      if (controller.isSuccess.value) {
        return Scaffold(
          backgroundColor: {{colorsClass}}.background,
          body: SafeArea(
            child: Padding(
              padding: const EdgeInsets.all({{dimensionsClass}}.lg),
              child: Column(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  const Icon(
                    Icons.check_circle_outline,
                    size: 72,
                    color: {{colorsClass}}.success,
                  ),
                  const SizedBox(height: {{dimensionsClass}}.lg),
                  Text(
                    'Account deleted',
                    style: {{textStylesClass}}.heading2,
                    textAlign: TextAlign.center,
                  ),
                  const SizedBox(height: {{dimensionsClass}}.sm),
                  Text(
                    'Your account has been permanently removed.',
                    style: {{textStylesClass}}.bodyMedium.copyWith(
                      color: {{colorsClass}}.textSecondary,
                    ),
                    textAlign: TextAlign.center,
                  ),
                ],
              ),
            ),
          ),
        );
      }

      return Scaffold(
        backgroundColor: {{colorsClass}}.background,
        appBar: AppBar(
          backgroundColor: Colors.transparent,
          elevation: 0,
          leading: BackButton(
            color: {{colorsClass}}.textPrimary,
            onPressed: controller.goBack,
          ),
        ),
        body: SafeArea(
          child: Padding(
            padding: const EdgeInsets.all({{dimensionsClass}}.lg),
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.start,
              children: [
                const SizedBox(height: {{dimensionsClass}}.md),
                Text({{stringsClass}}.accountDelete, style: {{textStylesClass}}.heading1),
                const SizedBox(height: {{dimensionsClass}}.sm),
                Text(
                  'This action is permanent. Type DELETE to confirm.',
                  style: {{textStylesClass}}.bodyMedium.copyWith(
                    color: {{colorsClass}}.textSecondary,
                  ),
                ),
                const SizedBox(height: {{dimensionsClass}}.xl),
                TextInput(
                  label: 'Type DELETE',
                  controller: controller.confirmationController,
                ),
                Obx(() {
                  final error = controller.errorMessage.value;
                  if (error == null) return const SizedBox.shrink();
                  return Padding(
                    padding: const EdgeInsets.only(top: {{dimensionsClass}}.sm),
                    child: Text(
                      error,
                      style: {{textStylesClass}}.caption.copyWith(
                        color: {{colorsClass}}.error,
                      ),
                    ),
                  );
                }),
                const SizedBox(height: {{dimensionsClass}}.xl),
                Obx(
                  () => PrimaryButton(
                    label: {{stringsClass}}.accountDelete,
                    isLoading: controller.isLoading.value,
                    onPressed: controller.submit,
                  ),
                ),
              ],
            ),
          ),
        ),
      );
    });
  }
}
