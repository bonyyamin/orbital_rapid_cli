void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  
{{#isFirebaseBackend}}
  // Initialize Firebase with placeholder configuration
  await Firebase.initializeApp(
    options: const FirebaseOptions(
      apiKey: 'YOUR_FIREBASE_API_KEY',
      appId: 'YOUR_FIREBASE_APP_ID',
      messagingSenderId: 'YOUR_FIREBASE_SENDER_ID',
      projectId: 'YOUR_FIREBASE_PROJECT_ID',
    ),
  );
  debugPrint('Firebase initialized with placeholder config');
{{/isFirebaseBackend}}
{{#isRestBackend}}
  // Initialize REST API configuration
  debugPrint('REST API initialized with placeholder config');
  final storageService = await StorageService.getInstance();
{{/isRestBackend}}
{{#isSupabaseBackend}}
  // Initialize Supabase configuration
  debugPrint('Supabase initialized with placeholder config');
{{/isSupabaseBackend}}
{{#isNoneBackend}}
  // No backend selected - using local storage only
  debugPrint('Running in no-backend mode (local storage only)');
{{/isNoneBackend}}
  
  final authRepository = {{#isFirebaseBackend}}FirebaseAuthRepository();{{/isFirebaseBackend}}
                         {{#isRestBackend}}RestAuthRepository(storage: storageService);{{/isRestBackend}}
                         {{#isSupabaseBackend}}SupabaseAuthRepository();{{/isSupabaseBackend}}
                         {{#isNoneBackend}}NoAuthRepository();{{/isNoneBackend}}

  runApp(
    MultiRepositoryProvider(
      providers: [
        RepositoryProvider<AuthRepositoryInterface>(
          create: (context) => authRepository,
        ),
      ],
      child: MultiBlocProvider(
        providers: [
          BlocProvider<AuthBloc>(
            create: (context) => AuthBloc(authRepository: authRepository),
          ),
          {{#hasSplashScreen}}
          BlocProvider<SplashBloc>(
            create: (context) => SplashBloc(),
          ),
          {{/hasSplashScreen}}
          {{#hasOnboardingScreen}}
          BlocProvider<OnboardingBloc>(
            create: (context) => OnboardingBloc(),
          ),
          {{/hasOnboardingScreen}}
          {{#hasLoginScreen}}
          BlocProvider<LoginBloc>(
            create: (context) => LoginBloc(LoginUseCase(authRepository)),
          ),
          {{/hasLoginScreen}}
          {{#hasRegisterScreen}}
          BlocProvider<RegisterBloc>(
            create: (context) => RegisterBloc(RegisterUseCase(authRepository)),
          ),
          {{/hasRegisterScreen}}
          {{#hasForgotPasswordScreen}}
          BlocProvider<ForgotPasswordBloc>(
            create: (context) => ForgotPasswordBloc(ForgotPasswordUseCase(authRepository)),
          ),
          {{/hasForgotPasswordScreen}}
          {{#hasDeleteAccountScreen}}
          BlocProvider<DeleteAccountBloc>(
            create: (context) => DeleteAccountBloc(authRepository.deleteAccount),
          ),
          {{/hasDeleteAccountScreen}}
        ],
        child: const {{projectNamePascal}}App(),
      ),
    ),
  );
}

