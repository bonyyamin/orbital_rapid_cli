void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  
{{#isFirebaseBackend}}
  // Initialize Firebase with placeholder configuration
  // Replace these values with your actual Firebase project credentials
  // Go to: https://console.firebase.google.com/ to get your project details
  await Firebase.initializeApp(
    options: const FirebaseOptions(
      apiKey: 'YOUR_FIREBASE_API_KEY',        // Replace with your Firebase API key
      appId: 'YOUR_FIREBASE_APP_ID',          // Replace with your Firebase App ID
      messagingSenderId: 'YOUR_FIREBASE_SENDER_ID', // Replace with your Sender ID
      projectId: 'YOUR_FIREBASE_PROJECT_ID',  // Replace with your Project ID
    ),
  );
  debugPrint('Firebase initialized with placeholder config');
{{/isFirebaseBackend}}
{{#isRestBackend}}
  // Initialize REST API configuration
  // Update ApiConfig with your actual API endpoints and keys
  debugPrint('REST API initialized with placeholder config');
  debugPrint('Base URL: ${ApiConfig.baseUrl}');
{{/isRestBackend}}
{{#isSupabaseBackend}}
  // Initialize Supabase configuration
  // Update SupabaseConfig with your actual Supabase project credentials
  // Go to: https://app.supabase.com/ to get your project details
  debugPrint('Supabase initialized with placeholder config');
  debugPrint('Supabase URL: ${SupabaseConfig.url}');
{{/isSupabaseBackend}}
{{#isNoneBackend}}
  // No backend selected - using local storage only
  debugPrint('Running in no-backend mode (local storage only)');
{{/isNoneBackend}}
  
  // Initialize shared preferences for local storage
  final sharedPrefs = await SharedPreferences.getInstance();
  
  runApp(
    ProviderScope(
      overrides: [
        sharedPreferencesProvider.overrideWithValue(sharedPrefs),
      ],
      child: const {{projectNamePascal}}App(),
    ),
  );
}

class {{projectNamePascal}}App extends StatelessWidget {
  const {{projectNamePascal}}App({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: '{{projectNamePascal}}',
      debugShowCheckedModeBanner: false,
      theme: AppTheme.light,
{{#hasDarkMode}}
      darkTheme: AppDarkTheme.dark,
      themeMode: ThemeMode.system,
{{/hasDarkMode}}
      initialRoute: AppRoutes.splash,
      routes: AppRoutes.routes,
    );
  }
}
